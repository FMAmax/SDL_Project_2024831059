            "type": "shell",
            "command": "g++ \"$(cygpath -u '${workspaceFolder}/task101.cpp')\" -o \"$(cygpath -u '${workspaceFolder}/task101.exe')\" -I \"$(cygpath -u '${workspaceFolder}/src/include')\" -L \"$(cygpath -u '${workspaceFolder}/src/lib')\" -lSDL3 -mwindows -Wall -g",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "detail": "Builds task101.cpp into task101.exe"
        },
