{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Debug SDL3 App",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Task10X.exe", // Path to your compiled executable
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true, // Set to true to see console output in a separate window
            "MIMode": "gdb", 
            "miDebuggerPath": "C:/GCC new version/bin/gdb.exe", // Adjusted to your gdb debugger path
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build sdl3 app" // Ensures the project is built before debugging
        }
    ]
}